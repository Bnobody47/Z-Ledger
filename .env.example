# Copy to .env and add your keys. Run scripts/setup_all.sql first to create user and DB.
DATABASE_URL=postgresql://bnobody:beahhal@localhost:5432/z_ledger

# Anthropic (fallback if OPENROUTER_API_KEY is not set)
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE

# OpenRouter (preferred)
OPENROUTER_API_KEY=or-YOUR_KEY_HERE
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1/chat/completions

# Optional: applicant registry (same DB by default)
APPLICANT_REGISTRY_URL=postgresql://bnobody:beahhal@localhost:5432/z_ledger

# Paths
DOCUMENTS_DIR=./documents

# Regulatory
REGULATION_VERSION=2026-Q1
LOG_LEVEL=INFO
